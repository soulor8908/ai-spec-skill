{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "types": ["node"],
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": ".",
    "noEmit": false,
    "emitDeclarationOnly": false
  },
  "include": [
    "src/**/*.ts",
    "cli/**/*.ts"
  ],
  "exclude": [
    "test/**/*.ts",
    "dist/**",
    "node_modules/**"
  ]
}
